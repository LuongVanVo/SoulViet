{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",

  "ConnectionStrings": {
    "DefaultConnection": "Host=%DB_HOST%;Port=%DB_PORT%;Database=%DB_NAME%;Username=%DB_USER%;Password=%DB_PASSWORD%"
  },

  "RabbitMQ": {
    "HostName": "%RABBITMQ_HOST%",
    "UserName": "%RABBITMQ_USER%",
    "Password": "%RABBITMQ_PASSWORD%"
  }
}

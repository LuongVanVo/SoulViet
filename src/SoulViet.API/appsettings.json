{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ClientUrl": "%CLIENT_URL%",
  "ConnectionStrings": {
    "DefaultConnection": "%DB_CONNECTION_STRING%"
  },
  "Redis": {
    "ConnectionString": "%REDIS_CONN%",
    "AbsoluteExpirationMinutes": 15
  },
  "RabbitMQ": {
    "HostName": "%RABBITMQ_HOST%",
    "UserName": "%RABBITMQ_USER%",
    "Password": "%RABBITMQ_PASSWORD%"
  },
  "MailSettings": {
    "Server": "%SMTP_SERVER%",
    "Port": 587,
    "SenderName": "%SMTP_SENDER_NAME%",
    "SenderEmail": "%SMTP_SENDER_EMAIL%",
    "Password": "%SMTP_PASSWORD%"
  },
  "CloudinarySettings": {
    "CloudName": "",
    "ApiKey": "",
    "ApiSecret": ""
  },

  "CloudflareR2Settings": {
    "AccessKey": "",
    "SecretKey": "",
    "ServiceUrl": "",
    "BucketName": "soulviet-media",
    "PublicDomain": ""
  },

  "JWT_EXPIRY_MINUTES": "%JWT_EXPIRY_MINUTES%",
  "COOKIE_EXPIRY_DAYS": "%COOKIE_EXPIRY_DAYS%",

  "VnPay": {
    "TmnCode": "%VN_PAY_TMN_CODE%",
    "HashSecret": "%VN_PAY_HASH_SECRET%",
    "BaseUrl": "%VN_PAY_BASE_URL%",
    "ReturnUrl": "%VN_PAY_RETURN_URL%",
    "Version": "2.1.0",
    "Command": "pay",
    "CurrencyCode": "VND",
    "Locale": "vn"
  }
}
